{
  "expo": {
    "name": "ProfCalendar",
    "slug": "profcalendar-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "scheme": "profcalendar",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.profcalendar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Pour téléverser des fichiers ou documents",
        "NSCameraUsageDescription": "Pour scanner des documents",
        "NSDocumentsFolderUsageDescription": "Pour accéder et enregistrer tes fichiers"
      }
    },
    "android": {
      "package": "com.profcalendar.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4F46E5"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "13bca72c-5070-4c4b-a4db-9d785f1e805b"
      }
    },
    "owner": "minibrasiler"
  }
}